# Copiar a .env (gitignoreado) y completar. NUNCA commitear .env.
# Cada entorno vive en su propia cuenta AWS; el deploy elige con `-c env=dev|prod` (default dev).

# Cuenta AWS de desarrollo (12 dígitos)
DEV_ACCOUNT=

# Cuenta AWS de producción
PROD_ACCOUNT=

# Cuenta raíz de la organización (no se despliega ahí; solo referencia)
ROOT_ACCOUNT=

# Email del equipo: recibe avisos de reservas/mensajes (SES manda un link de verificación al desplegar)
NOTIFICATION_EMAIL=

# Opcional: dominio raíz (ej. randomtrips.com). Si se define, se crea la Hosted Zone en Route 53.
# DOMAIN_NAME=
